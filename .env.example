# =======================
# JWT Configuration
# =======================
# Secret key for JWT tokens (minimum 32 characters)
JWT_SECRET=your_jwt_secret_here_min_32_chars_change_in_production

# =======================
# Supabase Configuration
# =======================
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_URL=https://your-project.supabase.co

# =======================
# Server Configuration
# =======================
PORT=3000
NODE_ENV=development

# =======================
# CORS Configuration
# =======================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5174

# =======================
# Rate Limiting
# =======================
# Time window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000
# Maximum requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100
# Login attempts limit (default: 5)
LOGIN_RATE_LIMIT_MAX=5
# Login attempts window in milliseconds (default: 900000 = 15 minutes)
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# =======================
# Logging
# =======================
# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
# Pretty print logs in development (true/false)
LOG_PRETTY=true

# Zoom Configuration (Video Calls)
# Server-to-Server OAuth App
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# Meeting SDK App
ZOOM_SDK_KEY=your_zoom_sdk_key
ZOOM_SDK_SECRET=your_zoom_sdk_secret

# Tareas Programadas
# Cambiar a 'false' en producción para ejecutar diariamente a la 1 AM
TASKS_TESTING_MODE=true

# Días de retención de actividades en tabla activa (por defecto: 90)
DIAS_RETENCION_ACTIVIDADES=90

# Días de retención total en archivo antes de eliminar (por defecto: 365)
DIAS_ARCHIVO_TOTAL=365

DIAS_RETENCION_QUERY_LOGS=1

# ===================================
# WORKERS CONFIGURATION
# ===================================

# Cluster Mode (Multi-proceso para aprovechar múltiples CPUs)
# true = Modo cluster (recomendado para producción)
# false = Modo single process (recomendado para desarrollo)
USE_CLUSTER=false

# Número de procesos cluster workers
# Por defecto: CPUs - 1 (dejar 1 CPU libre)
# Ejemplo: 4 workers para servidor con 4-8 cores
CLUSTER_WORKERS=4

# Worker Threads (Para tareas CPU-intensive)
# true = Habilitar worker threads (recomendado)
# false = Procesamiento síncrono
USE_WORKER_THREADS=true

# Número de worker threads en el pool
# Por defecto: 4 workers
# Recomendación: 2-8 workers dependiendo de la carga
WORKER_THREADS=4

# ===================================
# WORKERS USAGE GUIDE
# ===================================
#
# Desarrollo local:
#   USE_CLUSTER=false
#   USE_WORKER_THREADS=true
#   WORKER_THREADS=2
#
# Producción (servidor pequeño 2-4 cores):
#   USE_CLUSTER=true
#   CLUSTER_WORKERS=2
#   USE_WORKER_THREADS=true
#   WORKER_THREADS=4
#
# Producción (servidor grande 8+ cores):
#   USE_CLUSTER=true
#   CLUSTER_WORKERS=6
#   USE_WORKER_THREADS=true
#   WORKER_THREADS=8
#
# ===================================
