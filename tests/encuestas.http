# Pruebas de API de Encuestas
# Archivo para probar los endpoints con herramientas como Thunder Client, Postman, o REST Client

### Variables
@baseUrl = http://localhost:3000/api
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..aI-c5TSlMrt3UME0n780DRQ4CF_dMXjAL_--LIaP0vU

### 1. Obtener todas las encuestas
GET {{baseUrl}}/encuestas
Authorization: Bearer {{token}}

### 2. Obtener encuestas activas
GET {{baseUrl}}/encuestas?estado=activa
Authorization: Bearer {{token}}

### 3. Obtener encuestas cerradas
GET {{baseUrl}}/encuestas?estado=cerrada
Authorization: Bearer {{token}}

### 4. Obtener una encuesta específica
GET {{baseUrl}}/encuestas/1
Authorization: Bearer {{token}}

### 5. Crear encuesta (solo administradores)
POST {{baseUrl}}/encuestas
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "titulo": "Encuesta de Satisfacción - Taller de Vue.js",
  "descripcion": "Queremos conocer tu opinión sobre el taller de Vue.js impartido este mes",
  "fecha_fin": "2025-12-31",
  "preguntas": [
    {
      "texto": "¿Cómo calificarías el contenido del taller?",
      "tipo": "multiple",
      "opciones": [
        { "texto": "Excelente" },
        { "texto": "Muy bueno" },
        { "texto": "Bueno" },
        { "texto": "Regular" }
      ]
    },
    {
      "texto": "¿El ritmo de la clase fue adecuado?",
      "tipo": "multiple",
      "opciones": [
        { "texto": "Muy rápido" },
        { "texto": "Adecuado" },
        { "texto": "Lento" }
      ]
    },
    {
      "texto": "¿Qué temas adicionales te gustaría aprender?",
      "tipo": "abierta"
    }
  ]
}

### 6. Responder a una encuesta
POST {{baseUrl}}/encuestas/1/respuestas
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "respuestas": {
    "1": [1, 2],
    "2": "Me gustaría aprender sobre Vuex y Pinia"
  }
}

### 7. Obtener resultados de una encuesta
GET {{baseUrl}}/encuestas/1/resultados
Authorization: Bearer {{token}}

### 8. Publicar una encuesta (solo administradores)
PATCH {{baseUrl}}/encuestas/1/publicar
Authorization: Bearer {{token}}

### 9. Probar error: Crear encuesta sin autenticación
POST {{baseUrl}}/encuestas
Content-Type: application/json

{
  "titulo": "Test sin auth",
  "descripcion": "Debe fallar",
  "fecha_fin": "2025-12-31",
  "preguntas": []
}

### 10. Probar error: Responder encuesta duplicada
POST {{baseUrl}}/encuestas/1/respuestas
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "respuestas": {
    "1": [1]
  }
}

### 11. Crear encuesta con fecha pasada (debe fallar)
POST {{baseUrl}}/encuestas
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "titulo": "Encuesta con fecha inválida",
  "descripcion": "Esta encuesta no debe crearse",
  "fecha_fin": "2020-01-01",
  "preguntas": [
    {
      "texto": "Pregunta test",
      "tipo": "abierta"
    }
  ]
}

### 12. Crear encuesta sin preguntas (debe fallar)
POST {{baseUrl}}/encuestas
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "titulo": "Encuesta sin preguntas",
  "descripcion": "Esta no debe crearse",
  "fecha_fin": "2025-12-31",
  "preguntas": []
}

### 13. Crear pregunta múltiple sin opciones (debe fallar)
POST {{baseUrl}}/encuestas
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "titulo": "Encuesta con error",
  "descripcion": "Pregunta múltiple sin opciones",
  "fecha_fin": "2025-12-31",
  "preguntas": [
    {
      "texto": "¿Te gustó?",
      "tipo": "multiple",
      "opciones": []
    }
  ]
}

### 14. Crear encuesta compleja con múltiples preguntas
POST {{baseUrl}}/encuestas
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "titulo": "Evaluación Integral - Plataforma reConecta",
  "descripcion": "Ayúdanos a mejorar todos los aspectos de nuestra plataforma",
  "fecha_fin": "2026-01-15",
  "preguntas": [
    {
      "texto": "¿Qué tan satisfecho estás con la plataforma en general?",
      "tipo": "multiple",
      "opciones": [
        { "texto": "Muy satisfecho" },
        { "texto": "Satisfecho" },
        { "texto": "Neutral" },
        { "texto": "Insatisfecho" }
      ]
    },
    {
      "texto": "¿La navegación es intuitiva?",
      "tipo": "multiple",
      "opciones": [
        { "texto": "Sí, muy fácil" },
        { "texto": "Aceptable" },
        { "texto": "Difícil de usar" }
      ]
    },
    {
      "texto": "¿Qué funcionalidad te gustaría que agreguemos?",
      "tipo": "abierta"
    },
    {
      "texto": "¿Recomendarías reConecta a otros?",
      "tipo": "multiple",
      "opciones": [
        { "texto": "Definitivamente sí" },
        { "texto": "Probablemente sí" },
        { "texto": "No estoy seguro" },
        { "texto": "Probablemente no" }
      ]
    },
    {
      "texto": "Comentarios o sugerencias adicionales",
      "tipo": "abierta"
    }
  ]
}
